# Development Environment Configuration
# Copy this file to .env.local for local development

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_afterschool_dev?connection_limit=10"

# NextAuth
NEXTAUTH_SECRET="development-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# PDF Storage (local filesystem for development)
PDF_STORAGE_TYPE=local
PDF_STORAGE_PATH="./public/reports"

# MinIO (for development testing with S3 storage)
# Uncomment to test S3 storage locally
# MINIO_ENDPOINT=localhost:9000
# MINIO_REGION=us-east-1
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=reports

# Cloudinary (image upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# API Key Encryption (Multi-LLM - development dummy value)
API_KEY_ENCRYPTION_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Logging
LOG_LEVEL=debug
