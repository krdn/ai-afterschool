# Global options
{
    # Email for Let's Encrypt notifications
    email {$CADDY_EMAIL:admin@example.com}

    # Agree to Let's Encrypt terms
    on_demand_tls {
        ask http://app:3000/api/health
    }
}

# Production domain
{$APP_DOMAIN:ai-afterschool.example.com} {
    # Reverse proxy to Next.js app
    reverse_proxy app:3000 {
        # Health check upstream
        health_uri /api/health
        health_interval 30s
        health_timeout 10s

        # Headers to pass to backend
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"

        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"

        # XSS protection
        X-XSS-Protection "1; mode=block"

        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"

        # HSTS (uncomment once SSL is working)
        # Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        # Remove server header
        -Server
    }

    # Compress responses
    encode {
        zstd
        gzip
        level 5
    }

    # Log format
    log {
        output file /var/log/caddy/access.log
        format json
        level INFO
    }
}

# HTTP to HTTPS redirect
http://{$APP_DOMAIN:ai-afterschool.example.com} {
    redir https://{$APP_DOMAIN:ai-afterschool.example.com}{uri} permanent
}

# Local development (no SSL)
:80 {
    reverse_proxy app:3000 {
        health_uri /api/health
        health_interval 30s
        health_timeout 10s
    }

    # Enable CORS for development
    header {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
        -Server
    }
}
