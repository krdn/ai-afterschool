generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Teacher {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students            Student[]
  passwordResetTokens PasswordResetToken[]
}

model Student {
  id               String    @id @default(cuid())
  name             String
  nameHanja        Json?
  birthDate        DateTime
  birthTimeHour    Int?
  birthTimeMinute  Int?
  phone            String?
  school           String
  grade            Int
  targetUniversity String?
  targetMajor      String?
  bloodType        BloodType?

  teacherId        String
  teacher          Teacher   @relation(fields: [teacherId], references: [id])

  images           StudentImage[]
  sajuAnalysis     SajuAnalysis?
  nameAnalysis     NameAnalysis?
  mbtiSurveyDraft  MbtiSurveyDraft?
  mbtiAnalysis     MbtiAnalysis?

  calculationRecalculationNeeded Boolean  @default(false)
  calculationRecalculationReason String?
  calculationRecalculationAt     DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // PIPA compliance: retention period
  expiresAt        DateTime?

  @@index([teacherId])
  @@index([name])
  @@index([school])
}

model SajuAnalysis {
  id             String   @id @default(cuid())
  studentId      String   @unique
  inputSnapshot  Json
  result         Json
  interpretation String?
  status         String   @default("complete")
  version        Int      @default(1)
  calculatedAt   DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model NameAnalysis {
  id             String   @id @default(cuid())
  studentId      String   @unique
  inputSnapshot  Json
  result         Json
  interpretation String?
  status         String   @default("complete")
  version        Int      @default(1)
  calculatedAt   DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model MbtiSurveyDraft {
  id         String   @id @default(cuid())
  studentId  String   @unique
  responses  Json     // { "1": 3, "2": 5, ... } questionId: answerValue (1-5)
  progress   Int      @default(0) // Number of answered questions (0-60)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model MbtiAnalysis {
  id             String   @id @default(cuid())
  studentId      String   @unique
  responses      Json     // Full response data { "1": 3, "2": 5, ... }
  scores         Json     // { e: 12, i: 3, s: 8, n: 7, t: 10, f: 5, j: 11, p: 4 }
  mbtiType       String   // "ENTJ"
  percentages    Json     // { E: 80, I: 20, S: 53, N: 47, T: 67, F: 33, J: 73, P: 27 }
  interpretation String?  @db.Text // Long-form Korean description
  version        Int      @default(1)
  calculatedAt   DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentImage {
  id          String           @id @default(cuid())
  studentId   String
  type        StudentImageType
  originalUrl String
  resizedUrl  String
  publicId    String
  format      String?
  bytes       Int?
  width       Int?
  height      Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, type])
  @@index([studentId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
}

enum BloodType {
  A
  B
  AB
  O
}

enum StudentImageType {
  profile
  face
  palm
}
