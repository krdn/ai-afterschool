# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# backups - contains sensitive database dumps, never commit
/backups
/backups/*.sql.gz
/scripts/*.log

# Supabase local
supabase/

# Playwright MCP screenshots
.playwright-mcp/
obsidian/
.claude/CLAUDE.md
.claude/save-issue-trigger.json

# todo backlog
.todos/

# screenshots
prompt-preview-*.png
*.png

# uploaded files
/public/uploads
.claude/
.playwright-cli/

# logs (개발/디버그 로그)
*.log

# test output (테스트 결과 파일)
test-results*.json
full-test-results.txt

# debug config (디버그용 yaml)
*-debug.yaml
*-preview.yaml
login-page.yaml

# backup files
*.bak

# runtime state (배포 상태 파일)
.deploy-backup-tag

# pnpm (이 프로젝트는 npm 사용)
pnpm-lock.yaml

# one-off utility scripts in root
/check-*.js
/check-*.ts
