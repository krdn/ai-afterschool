      FROM "LLMUsage"
      WHERE "createdAt" >= '2026-01-07T00:35:11.672Z'
        AND "createdAt" <= '2026-02-06T00:35:11.672Z'
      GROUP BY DATE("createdAt")
      ORDER BY DATE("createdAt") ASC
    
