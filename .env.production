# Production Environment Configuration
# DO NOT commit this file to version control
# Copy .env.production.example and fill in actual values

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://ai-afterschool.example.com

# Database (Docker Compose networking)
DATABASE_URL="postgresql://postgres:CHANGE_ME_PASSWORD@postgres:5432/ai_afterschool?connection_limit=10"

# NextAuth
NEXTAUTH_SECRET="CHANGE_ME_generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://ai-afterschool.example.com"

# PDF Storage (MinIO/S3 for production)
PDF_STORAGE_TYPE=s3
PDF_STORAGE_PATH="./public/reports"
MINIO_ENDPOINT=minio:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=CHANGE_ME_minioadmin
MINIO_SECRET_KEY=CHANGE_ME_generate-strong-password
MINIO_BUCKET=reports

# Cloudinary (image upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Caddy (SSL)
CADDY_EMAIL=admin@example.com

# Logging
LOG_LEVEL=info

# Security
# Set these to strong values in production!
# Generate passwords: openssl rand -base64 32
