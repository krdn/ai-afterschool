# Staging Environment Configuration
# Used for pre-production testing

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://staging.ai-afterschool.example.com

# Database
DATABASE_URL="postgresql://postgres:staging_password@postgres:5432/ai_afterschool_staging?connection_limit=10"

# NextAuth
NEXTAUTH_SECRET="staging-secret-generate-with-openssl"
NEXTAUTH_URL="https://staging.ai-afterschool.example.com"

# PDF Storage (MinIO for staging)
PDF_STORAGE_TYPE=s3
MINIO_ENDPOINT=minio:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin-staging
MINIO_BUCKET=reports-staging

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Caddy
CADDY_EMAIL=admin@example.com

# Logging
LOG_LEVEL=debug

# Security
# Change these values for actual staging deployment
